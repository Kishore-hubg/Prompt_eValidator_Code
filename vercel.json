{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.py": {
      "runtime": "vercel-python@3.0.7",
      "maxDuration": 60,
      "excludeFiles": "{.venv/**,**/__pycache__/**,docs/**,scripts/**,*.db,.git/**,teams_bot/**}"
    }
  }
}
