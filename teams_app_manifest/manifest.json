{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "1.0.0",
  "id": "30a56efa-d58c-4e4b-a52d-f34018e4d8b9",
  "packageName": "com.infovision.promptvalidator",
  "developer": {
    "name": "Infovision",
    "websiteUrl": "https://promptvalidatorcompleterepo.vercel.app",
    "privacyUrl": "https://promptvalidatorcompleterepo.vercel.app/privacy",
    "termsOfUseUrl": "https://promptvalidatorcompleterepo.vercel.app/terms"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "name": {
    "short": "Prompt Validator",
    "full": "Infovision Prompt Validator"
  },
  "description": {
    "short": "Validate & improve prompts in Teams",
    "full": "Persona-aware prompt validation, issue feedback, and auto-improved prompts directly in Microsoft Teams. Supports Developer, PM, BA, Support Staff, and All Employee personas."
  },
  "accentColor": "#6264A7",
  "bots": [
    {
      "botId": "89f80bcf-efa3-4a07-a4a4-e766f3557e98",
