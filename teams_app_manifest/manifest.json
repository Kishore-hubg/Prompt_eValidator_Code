      "supportsFiles": false,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": ["personal", "team", "groupchat"],
          "commands": [
            { "title": "help", "description": "Show available commands" },
            { "title": "persona", "description": "List available personas" },
            { "title": "set-persona", "description": "Set active persona (e.g. /set-persona persona_1)" },
            { "title": "my-persona", "description": "Show your current persona" },
            { "title": "last-score", "description": "Show your last validation score" }
          ]
        }
      ]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": [
    "promptvalidatorcompleterepo.vercel.app",
    "margy-nonevolutionary-korey.ngrok-free.dev"
  ],
  "webApplicationInfo": {
    "id": "7b6ec3f4-3759-48d6-a558-6a1bcd1824c6",
